{
  "name": "ipa-kids",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n tts,web -c magenta,cyan \"npm run tts\" \"vite\"",
    "dev:web": "vite",
    "tts": "node scripts/edge-tts-server.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "concurrently -k -n tts,web -c magenta,cyan \"npm run tts\" \"vite preview\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "phonemes:generate": "python3 scripts/generate-china48-phonemes.py"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "node-edge-tts": "^1.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
